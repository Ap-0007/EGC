{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EGC Skills Registry Schema",
  "description": "Physical mapping of EGC skill namespaces and directories",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "namespace", "path", "status", "source_directory"],
    "properties": {
      "name": { "type": "string" },
      "namespace": { "type": "string" },
      "path": { "type": "string" },
      "status": { "type": "string", "enum": ["VALID", "INVALID", "DEPRECATED"] },
      "source_directory": { "type": "string" }
    }
  }
}
