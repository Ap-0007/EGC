{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EGC Agents Registry Schema",
  "description": "Physical mapping of EGC agents and their model configurations",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "model", "tools", "path", "status"],
    "properties": {
      "name": { "type": "string" },
      "model": { "type": "string" },
      "tools": { "type": "array", "items": { "type": "string" } },
      "path": { "type": "string" },
      "status": { "type": "string", "enum": ["VALID", "INVALID", "DEPRECATED"] }
    }
  }
}
